{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "codebase": "default"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "functions/**",
      "node_modules/**",
      "docs/**",
      ".git/**",
      ".claude/**",
      "*.log",
      "*.md",
      "*.txt",
      "*.docx",
      "seed*",
      "export*",
      "package.json",
      "package-lock.json",
      "server.log"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
